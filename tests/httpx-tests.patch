+# Patch AsyncClient to use AsyncPyCurlTransport from httpx_pycurl
+def pytest_configure(config):
+    """Patch httpx.AsyncClient to use AsyncPyCurlTransport for asyncio tests."""
+    try:
+        from httpx_pycurl import AsyncPyCurlTransport
+
+        _original_send_single_request = httpx.AsyncClient._send_single_request
+
+        async def patched_send_single_request(self, request):
+            # Check if the current transport is the default and we should replace it
+            transport_name = type(self._transport).__name__
+            if transport_name in ("HTTPCoreAsyncTransport", "AsyncHTTPTransport"):
+                try:
+                    # Replace with pycurl transport only if not already patched
+                    if not hasattr(self, "_pycurl_patched"):
+                        self._transport = AsyncPyCurlTransport()
+                        self._pycurl_patched = True
+                except ImportError:
+                    pass
+
+            return await _original_send_single_request(self, request)
+
+        httpx.AsyncClient._send_single_request = patched_send_single_request
+    except Exception:
+        # httpx_pycurl not available or error during patching
+        pass
