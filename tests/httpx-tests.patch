diff --git a/tests/conftest.py b/tests/conftest.py
index 858bca1..b5d70c0 100644
--- a/tests/conftest.py
+++ b/tests/conftest.py
@@ -285,3 +285,84 @@ def server() -> typing.Iterator[TestServer]:
     config = Config(app=app, lifespan="off", loop="asyncio")
     server = TestServer(config=config)
     yield from serve_in_thread(server)
+
+
+# Patch Client and AsyncClient to use PyCurlTransport and AsyncPyCurlTransport
+_pycurl_patched = False
+
+
+def pytest_configure(config):
+    """Patch httpx.Client to use PyCurlTransport and httpx.AsyncClient to use AsyncPyCurlTransport."""
+    global _pycurl_patched
+    try:
+        from httpx_pycurl import PyCurlTransport, AsyncPyCurlTransport
+
+        # Patch sync Client to use PyCurlTransport
+        _original_sync_init = httpx.Client.__init__
+
+        def patched_sync_init(self, *args, **kwargs):
+            # If no transport is specified, we'll replace it with PyCurlTransport
+            _original_sync_init(self, *args, **kwargs)
+
+            # Check if the current transport is the default and replace it
+            transport_name = type(self._transport).__name__
+            if transport_name in ("HTTPCoreTransport", "HTTPTransport"):
+                try:
+                    # Replace with pycurl transport
+                    self._transport = PyCurlTransport()
+                except Exception as e:
+                    pass
+
+        httpx.Client.__init__ = patched_sync_init
+
+        # Patch AsyncClient to use AsyncPyCurlTransport
+        _original_async_init = httpx.AsyncClient.__init__
+
+        def patched_async_init(self, *args, **kwargs):
+            # Apply original init first
+            _original_async_init(self, *args, **kwargs)
+            # We'll replace transport at first request time to ensure event loop is running
+
+        httpx.AsyncClient.__init__ = patched_async_init
+
+        # Patch AsyncClient._send_single_request to replace transport at request time
+        _original_send_single_request = httpx.AsyncClient._send_single_request
+
+        async def patched_send_single_request(self, request):
+            # Only use pycurl transport for asyncio, not for trio
+            import asyncio
+
+            # Check if we're in asyncio (sniffio would be better but it's optional)
+            try:
+                asyncio.get_running_loop()
+                # We're in asyncio, safe to use pycurl
+                in_asyncio = True
+            except RuntimeError:
+                # Not in asyncio, likely trio
+                in_asyncio = False
+
+            # Check if the current transport is the default and we should replace it
+            transport_name = type(self._transport).__name__
+            if in_asyncio and transport_name in (
+                "HTTPCoreAsyncTransport",
+                "AsyncHTTPTransport",
+            ):
+                try:
+                    # Replace with pycurl transport only if not already patched
+                    if not hasattr(self, "_pycurl_patched"):
+                        old_transport = self._transport
+                        self._transport = AsyncPyCurlTransport()
+                        self._pycurl_patched = True
+                except Exception as e:
+                    pass
+
+            return await _original_send_single_request(self, request)
+
+        httpx.AsyncClient._send_single_request = patched_send_single_request
+        _pycurl_patched = True
+    except Exception as e:
+        # Debug: print any errors during patching
+        import traceback
+
+        traceback.print_exc()
+        pass
